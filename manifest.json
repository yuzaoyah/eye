{
  "manifest_version": 3,
  "name": "Eye",
  "version": "0.3",
  "description": "A custom new tab extension",
  "permissions": ["tabs", "activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/img/ico/default/icon_v4.png",
      "48": "/img/ico/default/icon_v4.png",
      "128": "/img/ico/default/icon_v4.png"
    }
  }
}
